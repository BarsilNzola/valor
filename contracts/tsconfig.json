{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "./hardhat.config.ts",
    "./script/**/*.ts",
    "./test/**/*.ts",
    "./typechain-types/**/*.ts"
  ],
  "files": ["./hardhat.config.ts"],
  "exclude": ["node_modules", "dist", "artifacts", "cache"]
}